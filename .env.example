# Multi DeepSeek support
DEEPSEEK_API_KEYS=key1,key2,key3
DEEPSEEK_MODELS=deepseek-chat,deepseek-coder
DEEPSEEK_ENDPOINTS=https://api.deepseek.com,https://deepseek.proxy.com/v1
DEEPSEEK_BALANCE_STRATEGY=round_robin
DEFAULT_MODEL=deepseek-chat

# Optional runtime tuning
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_COOLDOWN_SECONDS=30
DEEPSEEK_MAX_CONCURRENCY=8
