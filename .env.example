# DeepSeek official OpenAI-compatible API
# Docs: https://api-docs.deepseek.com/zh-cn/
# Multiple keys are comma-separated.
DEEPSEEK_API_KEYS=sk-...,sk-...

# Current DeepSeek model names. Legacy deepseek-chat/deepseek-reasoner aliases
# remain temporarily supported, but are deprecated after 2026-07-24.
DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
DEFAULT_MODEL=deepseek-v4-flash

# Official base URL. Do not add /v1 for the official DeepSeek endpoint.
# Custom OpenAI-compatible proxies/gateways may require their own /v1 path.
DEEPSEEK_ENDPOINTS=https://api.deepseek.com
# Optional proxy example:
# DEEPSEEK_ENDPOINTS=https://api.deepseek.com,https://your-proxy.example.com/v1
DEEPSEEK_BALANCE_STRATEGY=round_robin

# Retry/cooldown tuning for dynamic rate limits and transient network failures.
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=4
DEEPSEEK_COOLDOWN_SECONDS=60
DEEPSEEK_MAX_CONCURRENCY=4
